<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- Basic Settings -->
  <Id>1cc6f490-34ad-4931-ac57-8a4a685fdd63</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Maritime Paintball</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="IT Support Form"/>
  <Description DefaultValue="Opens IT Support submission form"/>
  <IconUrl DefaultValue="https://maritimepaintball.github.io/Submit-IT-Support-Outlook/Icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://maritimepaintball.github.io/Submit-IT-Support-Outlook/Icon-64.png"/>
  <SupportUrl DefaultValue="https://maritimepaintball.github.io/Submit-IT-Support-Outlook/"/>
  
  <!-- CRITICAL: AppDomains whitelist -->
  <AppDomains>
    <AppDomain>https://maritimepaintball.github.io</AppDomain>
    <AppDomain>https://forms.office.com</AppDomain>
  </AppDomains>
  
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>
  
  <!-- Permissions -->
  <Permissions>Restricted</Permissions>

  <!-- Form Settings -->
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://maritimepaintball.github.io/Submit-IT-Support-Outlook/taskpane.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <!-- Version Overrides for Ribbon Button -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">
      
      <Requirements>
        <bt:Sets DefaultMinVersion="1.3">
          <bt:Set Name="Mailbox"/>
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">
          
          <DesktopFormFactor>
            <!-- CRITICAL: FunctionFile reference -->
            <FunctionFile resid="Commands.Url"/>
            
            <!-- Message Read Mode -->
            <ExtensionPoint xsi:type="MessageReadCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgReadGroup">
                  <Label resid="GroupLabel"/>
                  <Control xsi:type="Button" id="msgReadOpenFormButton">
                    <Label resid="ButtonLabel"/>
                    <Supertip>
                      <Title resid="ButtonLabel"/>
                      <Description resid="ButtonTooltip"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16"/>
                      <bt:Image size="32" resid="Icon.32x32"/>
                      <bt:Image size="80" resid="Icon.80x80"/>
                    </Icon>
                    <Action xsi:type="ExecuteFunction">
                      <FunctionName>openForm</FunctionName>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

            <!-- Message Compose Mode -->
            <ExtensionPoint xsi:type="MessageComposeCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgComposeGroup">
                  <Label resid="GroupLabel"/>
                  <Control xsi:type="Button" id="msgComposeOpenFormButton">
                    <Label resid="ButtonLabel"/>
                    <Supertip>
                      <Title resid="ButtonLabel"/>
                      <Description resid="ButtonTooltip"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16"/>
                      <bt:Image size="32" resid="Icon.32x32"/>
                      <bt:Image size="80" resid="Icon.80x80"/>
                    </Icon>
                    <Action xsi:type="ExecuteFunction">
                      <FunctionName>openForm</FunctionName>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>
          </DesktopFormFactor>
        </Host>
      </Hosts>

      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16x16" DefaultValue="https://maritimepaintball.github.io/Submit-IT-Support-Outlook/Icon-16.png"/>
          <bt:Image id="Icon.32x32" DefaultValue="https://maritimepaintball.github.io/Submit-IT-Support-Outlook/Icon-32.png"/>
          <bt:Image id="Icon.80x80" DefaultValue="https://maritimepaintball.github.io/Submit-IT-Support-Outlook/Icon-80.png"/>
        </bt:Images>
        <bt:Urls>
          <bt:Url id="Commands.Url" DefaultValue="https://maritimepaintball.github.io/Submit-IT-Support-Outlook/commands.html"/>
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel" DefaultValue="IT Support"/>
          <bt:String id="ButtonLabel" DefaultValue="Submit Ticket"/>
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="ButtonTooltip" DefaultValue="Click to open IT support form"/>
        </bt:LongStrings>
      </Resources>
    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>
